generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Event {
  id               String   @id @default(cuid())
  slug             String   @unique
  title            String
  description      String

  eventTime        DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  category         String
  region           String
  country          String
  locationLabel    String

  confidenceScore  Int
  confidenceLabel  String

  importanceScore  Int
  importanceLabel  String

  status           String

  sourceCount      Int

  sourcesJson      Json
  timelineJson     Json
}

model IncomingReport {
  id               String   @id @default(cuid())

  source           String
  sourceType       String
  title            String
  description      String

  timestamp        DateTime
  createdAt        DateTime @default(now())

  category         String
  region           String
  country          String
  locationLabel    String

  actorsJson       Json
  keywordsJson     Json

  rawUrl           String
  confidenceSeed   String
}

model IngestionRun {
  id              String   @id @default(cuid())
  runType         String
  generatedCount  Int
  insertedCount   Int
  createdCount    Int
  mergedCount     Int
  reviewCount     Int
  errorCount      Int      @default(0)
  notesJson       Json
  createdAt       DateTime @default(now())
}